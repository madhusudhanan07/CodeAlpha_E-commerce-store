# ─── Root .gitignore ─────────────────────────────────────────────────────────

# Environment files (NEVER commit)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Firebase Admin Service Account Key (NEVER commit — contains private key)
*serviceAccountKey*.json
backend/config/serviceAccountKey.json

# Node modules
node_modules/
frontend/node_modules/

# Build outputs
frontend/dist/
frontend/.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# TypeScript
*.tsbuildinfo

# Coverage
coverage/
